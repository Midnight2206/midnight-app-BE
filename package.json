{
  "name": "f8_node_js",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "midnight",
  "type": "module",
  "imports": {
    "#root/*": "./*",
    "#src/*": "./src/*",
    "#routes/*": "./src/routes/*",
    "#controllers/*": "./src/controllers/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./utils/*",
    "#configs/*": "./src/configs/*",
    "#middlewares/*": "./src/middlewares/*",
    "#docs/*": "./src/docs/*",
    "#zodSchemas/*": "./src/zodSchemas/*"
  },
  "main": "server.js",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --no-webstorage\" DOTENV_CONFIG_PATH=.env.test jest",
    "test:watch": "cross-env NODE_OPTIONS=\"--experimental-vm-modules --no-webstorage\" DOTENV_CONFIG_PATH=.env.test jest --watch",
    "test:integration": "cross-env RUN_INTEGRATION_TESTS=1 NODE_OPTIONS=\"--experimental-vm-modules --no-webstorage\" DOTENV_CONFIG_PATH=.env.test jest",
    "dev": "DOTENV_CONFIG_PATH=.env.dev nodemon ./server.js",
    "worker": "DOTENV_CONFIG_PATH=.env.dev node ./worker.js",
    "backup:worker": "DOTENV_CONFIG_PATH=.env.dev node ./backupWorker.js",
    "worker:dev": "DOTENV_CONFIG_PATH=.env.dev nodemon ./worker.js",
    "bootstrap:super-admin": "DOTENV_CONFIG_PATH=.env.dev node scripts/bootstrapSuperAdmin.js",
    "backup:run": "DOTENV_CONFIG_PATH=.env.dev node --import=dotenv/config -e \"import('#services/backupScheduler.service.js').then((m) => m.runBackupNow())\"",
    "backup:restore": "DOTENV_CONFIG_PATH=.env.dev node ./scripts/restoreBackupFromDrive.js",
    "drive:oauth:url": "DOTENV_CONFIG_PATH=.env.dev node --import=dotenv/config ./scripts/googleDriveOAuth.js auth-url",
    "drive:oauth:exchange": "DOTENV_CONFIG_PATH=.env.dev node --import=dotenv/config ./scripts/googleDriveOAuth.js exchange",
    "backfill:military-search": "DOTENV_CONFIG_PATH=.env.dev node --import=dotenv/config scripts/backfillMilitarySearchNormalized.js",
    "dev:redis:start": "sh ./scripts/dev/redis.sh start",
    "dev:redis:stop": "sh ./scripts/dev/redis.sh stop",
    "dev:redis:down": "sh ./scripts/dev/redis.sh down",
    "dev:redis:logs": "sh ./scripts/dev/redis.sh logs",
    "dev:redis:status": "sh ./scripts/dev/redis.sh status",
    "dev:full:start": "sh ./scripts/dev/full.sh start",
    "dev:full:update": "sh ./scripts/dev/full.sh update",
    "dev:full:stop": "sh ./scripts/dev/full.sh stop",
    "dev:full:down": "sh ./scripts/dev/full.sh down",
    "dev:full:logs": "sh ./scripts/dev/full.sh logs",
    "dev:full:status": "sh ./scripts/dev/full.sh status",
    "dev:full:restart": "sh ./scripts/dev/full.sh restart",
    "prod:start": "sh ./scripts/prod/full.sh start",
    "prod:update": "sh ./scripts/prod/full.sh update",
    "prod:stop": "sh ./scripts/prod/full.sh stop",
    "prod:down": "sh ./scripts/prod/full.sh down",
    "prod:logs": "sh ./scripts/prod/full.sh logs",
    "prod:status": "sh ./scripts/prod/full.sh status",
    "prod:restart": "sh ./scripts/prod/full.sh restart",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "cross-env DOTENV_CONFIG_PATH=.env.dev prisma migrate dev",
    "prisma:migrate:deploy": "cross-env DOTENV_CONFIG_PATH=.env.prod prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.3",
    "prisma": "^7.3.0",
    "rate-limiter-flexible": "^9.1.1",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.11",
    "hono": "4.12.8",
    "qs": "6.15.0"
  }
}
