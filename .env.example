# Copy this file to `.env.dev` for local development or `.env.prod` for production.
# Example:
#   cp .env.example .env.dev
#   cp .env.example .env.prod
# Fill in the values below. Keep `.env.*` out of git.

# =========================
# App / domain
# =========================
NODE_ENV=
PORT=
TZ=
API_DOMAIN=
FRONTEND_APP_URL=
ALLOW_ORIGIN=
VERIFY_EMAIL_FE_PATH=
PERMISSION_SYNC_ON_BOOT=

# =========================
# Database (MySQL / MariaDB)
# =========================
DB_ROOT_PASSWORD=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DATABASE_URL=
DB_CONNECTION_LIMIT=
DB_CONNECT_TIMEOUT=
DB_ACQUIRE_TIMEOUT=
DB_INIT_TIMEOUT=
DB_MIGRATE_MAX_RETRIES=
DB_MIGRATE_RETRY_DELAY_SECONDS=

# =========================
# JWT / auth
# =========================
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES=
JWT_EMAIL_SECRET=
JWT_EMAIL_EXPIRES=
REFRESH_TOKEN_EXPIRES=

# =========================
# Super admin bootstrap
# =========================
RUN_SUPERADMIN_BOOTSTRAP=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_ROLE=

# =========================
# Redis / queue
# =========================
REDIS_URL=
REDIS_HOST=
REDIS_PORT=
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=
VERIFY_EMAIL_JOB_CONCURRENCY=
VERIFY_EMAIL_JOB_ATTEMPTS=
VERIFY_EMAIL_JOB_BACKOFF_MS=
VERIFY_EMAIL_COOLDOWN_MS=

# =========================
# Email delivery
# =========================
EMAIL_DELIVERY_MODE=
EMAIL_WEBHOOK_URL=
EMAIL_FROM=
ADMIN_EMAIL=

# Gmail mode
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SMTP mode
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=

# MAIL_* compatibility
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# =========================
# Backup scheduler
# =========================
BACKUP_CRON_ENABLED=
BACKUP_CRON=
BACKUP_RUN_ON_BOOT=
BACKUP_WORK_DIR=
BACKUP_KEEP_LOCAL_FILES=
BACKUP_STORAGE=
BACKUP_MYSQLDUMP_BIN=
BACKUP_MYSQL_BIN=
BACKUP_ENCRYPTION_KEY=
BACKUP_NOTIFY_EMAILS=
BACKUP_RESTORE_FILE_ID=

# =========================
# Google Drive backup
# =========================
GDRIVE_FOLDER_ID=
GDRIVE_AUTH_MODE=
GDRIVE_SERVICE_ACCOUNT_EMAIL=
GDRIVE_PRIVATE_KEY=
GDRIVE_TOKEN_URI=
GDRIVE_SCOPE=
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_OAUTH_REFRESH_TOKEN=
GDRIVE_OAUTH_TOKEN_URI=
GDRIVE_OAUTH_REDIRECT_URI=

# Legacy compatibility
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
